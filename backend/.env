# ============================================
# 🔐 CONFIGURATION MONGODB ATLAS
# ============================================
# Remplacez par votre vraie URI copiée depuis Atlas
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?options
MONGO_URI="mongodb+srv://pfe_user:alinouh2000@cluster0.nfis1sl.mongodb.net/?appName=Cluster0"

# Nom de la base de données (Atlas la créera automatiquement au premier envoi)
DB_NAME="pv_monitor_db"

# ============================================
# ⚠️ SEUILS D'ALERTE POUR L'ENCRASSEMENT
# ============================================
# Seuil d'avertissement (%) - Niveau d'encrassement modéré
SEUIL_WARNING=30
# Seuil critique (%) - Niveau d'encrassement élevé nécessitant nettoyage urgent
SEUIL_CRITICAL=60

# ============================================
# 📧 CONFIGURATION EMAIL (SMTP GMAIL)
# ============================================
# Expéditeur des alertes (doit être un compte Gmail)
ALERT_EMAIL_FROM=alinouh057@gmail.com
# Mot de passe d'application Gmail (généré dans les paramètres de sécurité Google)
# Format: 16 caractères sans espaces
ALERT_EMAIL_PASS=hpsw lnjm qdjw efvw
# Destinataire des alertes (peut être le même ou différent)
ALERT_EMAIL_TO=alinouh701@gmail.com

# Serveur SMTP Gmail
SMTP_HOST=smtp.gmail.com
# Port SMTP avec TLS (587 pour STARTTLS)
SMTP_PORT=587

# ============================================
# 🔑 SÉCURITÉ JWT (JSON Web Tokens)
# ============================================
# Clé secrète pour signer les tokens JWT
# IMPORTANT: À changer en production - doit être longue et complexe
JWT_SECRET_KEY=une_clé_très_longue_et_secrète_au_moins_32_caractères

# ============================================
# ⏱️ COOLDOWN DES ALERTES (en minutes)
# ============================================
# Temps d'attente avant de renvoyer une alerte de niveau WARNING
COOLDOWN_WARNING=30
# Temps d'attente avant de renvoyer une alerte de niveau CRITICAL
COOLDOWN_CRITICAL=15
# Intervalle de vérification des alertes (en minutes)
CHECK_INTERVAL=60

# ============================================
# 🧹 NETTOYAGE AUTOMATIQUE DES IMAGES
# ============================================
# Durée de conservation des images (en jours)
IMAGE_RETENTION_DAYS=7
# Fréquence du nettoyage automatique (en heures)
CLEANUP_INTERVAL_HOURS=24

# ============================================
# 🔐 JWT - REDONDANT (fusionner avec le précédent)
# ============================================
# Ajouter à la fin du fichier .env
# Note: Cette ligne est redondante avec la précédente
# À garder pour compatibilité ou supprimer la première
JWT_SECRET_KEY=ma-cle-secrete-tres-longue-pour-jwt-2026-change-moi-en-production

# ============================================
# 👑 ADMIN INITIAL (premier utilisateur)
# ============================================
# Email du premier administrateur (créé automatiquement au démarrage)
ADMIN_EMAIL=alinouh057@gmail.com      # ← Mets ton email ici
# Mot de passe du premier admin (optionnel - généré automatiquement si vide)
ADMIN_PASSWORD=alinouh2000   # ← Optionnel
# Nom du premier administrateur
ADMIN_NAME="First Admin"